{% extends '@Planer/admin/_layout.html.twig' %}

{% block panel_title %}Nowy departament — Panel planera{% endblock %}
{% block panel_heading %}Nowy departament{% endblock %}

{% block panel_content %}
<form method="post">
    <div class="mb-3">
        <label class="form-label required" for="nazwa">Nazwa</label>
        <input type="text" class="form-control" id="nazwa" name="nazwa" required maxlength="100">
    </div>
    <div class="mb-3">
        <label class="form-label required" for="skrot">Skrót</label>
        <input type="text" class="form-control" id="skrot" name="skrot" required maxlength="10" style="width:150px;">
    </div>
    <div class="mb-3">
        <label class="form-label" for="kolejnosc">Kolejność</label>
        <input type="number" class="form-control" id="kolejnosc" name="kolejnosc" value="0" style="width:100px;">
    </div>
    {% if allDepartamenty is defined and allDepartamenty|length > 0 %}
    <div class="mb-3">
        <label class="form-label">Podgląda działy</label>
        <small class="form-text text-muted d-block mb-2">Pracownicy tego działu mogą podglądać grafiki wybranych działów (tylko do odczytu).</small>
        {% for d in allDepartamenty %}
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="podglada[]" value="{{ d.id }}" id="podglada_{{ d.id }}">
                <label class="form-check-label" for="podglada_{{ d.id }}">{{ d.nazwa }} ({{ d.skrot }})</label>
            </div>
        {% endfor %}
    </div>
    {% endif %}

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">Utwórz</button>
        <a href="{{ path('departament_index') }}" class="btn btn-secondary">Anuluj</a>
    </div>
</form>
{% endblock %}
