{% extends '@Planer/admin/_layout.html.twig' %}

{% block panel_title %}Edycja: {{ departament.nazwa }} — Panel planera{% endblock %}
{% block panel_heading %}Edycja: {{ departament.nazwa }}{% endblock %}

{% block panel_content %}
<form method="post">
    <div class="mb-3">
        <label class="form-label required" for="nazwa">Nazwa</label>
        <input type="text" class="form-control" id="nazwa" name="nazwa" value="{{ departament.nazwa }}" required maxlength="100">
    </div>
    <div class="mb-3">
        <label class="form-label required" for="skrot">Skrót</label>
        <input type="text" class="form-control" id="skrot" name="skrot" value="{{ departament.skrot }}" required maxlength="10" style="width:150px;">
    </div>
    <div class="mb-3">
        <label class="form-label" for="kolejnosc">Kolejność</label>
        <input type="number" class="form-control" id="kolejnosc" name="kolejnosc" value="{{ departament.kolejnosc }}" style="width:100px;">
    </div>
    {% if allDepartamenty|length > 1 %}
    <div class="mb-3">
        <label class="form-label">Podgląda działy</label>
        <small class="form-text text-muted d-block mb-2">Pracownicy tego działu mogą podglądać grafiki wybranych działów (tylko do odczytu).</small>
        {% for d in allDepartamenty %}
            {% if d.id != departament.id %}
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="podglada[]" value="{{ d.id }}" id="podglada_{{ d.id }}"
                    {{ d.id in departament.podgladaIds ? 'checked' : '' }}>
                <label class="form-check-label" for="podglada_{{ d.id }}">{{ d.nazwa }} ({{ d.skrot }})</label>
            </div>
            {% endif %}
        {% endfor %}
    </div>
    {% endif %}

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">Zapisz</button>
        <a href="{{ path('departament_index') }}" class="btn btn-secondary">Anuluj</a>
    </div>
</form>
{% endblock %}
