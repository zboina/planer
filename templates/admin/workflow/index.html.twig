{% extends '@Planer/admin/_layout.html.twig' %}

{% block panel_title %}Workflow akceptacji{% endblock %}
{% block panel_heading %}Workflow akceptacji podań{% endblock %}

{% block panel_actions %}
    <a href="{{ path('planer_admin_workflow_new') }}" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="16" height="16" viewBox="0 0 24 24"
             stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <path d="M12 5l0 14"/>
            <path d="M5 12l14 0"/>
        </svg>
        Dodaj krok
    </a>
{% endblock %}

{% block panel_content %}
<div class="mb-3">
    <div class="alert alert-info">
        Kroki workflow definiują łańcuch akceptacji podań urlopowych. Przeciągnij wiersze, aby zmienić kolejność.
        Typ <strong>Departamentowy</strong> wymaga akceptacji szefa działu pracownika, a typ <strong>Globalny</strong> wymaga użytkownika z przypisaną rolą (zakładka Role).
    </div>
</div>

{% if kroki is not empty %}
    <div data-controller="workflow-sort" data-workflow-sort-url-value="{{ path('planer_admin_workflow_sort') }}">
        {# Visual workflow chain #}
        <div class="mb-4">
            <div class="d-flex align-items-center flex-wrap gap-2" data-workflow-sort-target="chain">
                <span class="badge bg-yellow-lt py-2 px-3">Złożony</span>
                {% for krok in kroki %}
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon text-secondary" width="20" height="20" viewBox="0 0 24 24"
                         stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <path d="M5 12l14 0"/>
                        <path d="M15 16l4 -4"/>
                        <path d="M15 8l4 4"/>
                    </svg>
                    {% if krok.pomijalne %}
                        <span class="badge bg-secondary-lt py-2 px-3 text-decoration-line-through">
                            {{ krok.label }}
                            <span class="ms-1 small">(pominięty)</span>
                        </span>
                    {% else %}
                        <span class="badge {{ krok.type == 'department' ? 'bg-blue-lt' : 'bg-purple-lt' }} py-2 px-3">
                            {{ krok.label }}
                            <span class="ms-1 text-secondary small">({{ krok.type == 'department' ? 'dział' : 'rola' }})</span>
                        </span>
                    {% endif %}
                {% endfor %}
                <svg xmlns="http://www.w3.org/2000/svg" class="icon text-secondary" width="20" height="20" viewBox="0 0 24 24"
                     stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M5 12l14 0"/>
                    <path d="M15 16l4 -4"/>
                    <path d="M15 8l4 4"/>
                </svg>
                <span class="badge bg-green-lt py-2 px-3">Zatwierdzony</span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-vcenter">
                <thead>
                    <tr>
                        <th style="width: 40px;"></th>
                        <th style="width: 50px;">Lp.</th>
                        <th>Klucz</th>
                        <th>Nazwa</th>
                        <th>Typ</th>
                        <th class="text-center">Status</th>
                        <th class="text-center" style="width: 140px;">Akcje</th>
                    </tr>
                </thead>
                <tbody data-workflow-sort-target="body">
                    {% for krok in kroki %}
                        <tr data-id="{{ krok.id }}" data-label="{{ krok.label }}" data-type="{{ krok.type }}">
                            <td>
                                <span class="drag-handle cursor-grab text-secondary">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="18" height="18" viewBox="0 0 24 24"
                                         stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                        <path d="M9 5m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/>
                                        <path d="M9 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/>
                                        <path d="M9 19m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/>
                                        <path d="M15 5m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/>
                                        <path d="M15 12m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/>
                                        <path d="M15 19m-1 0a1 1 0 1 0 2 0a1 1 0 1 0 -2 0"/>
                                    </svg>
                                </span>
                            </td>
                            <td class="text-secondary lp">{{ loop.index }}</td>
                            <td><code>{{ krok.key }}</code></td>
                            <td>{{ krok.label }}</td>
                            <td>
                                {% if krok.type == 'department' %}
                                    <span class="badge bg-blue-lt">Departamentowy</span>
                                {% else %}
                                    <span class="badge bg-purple-lt">Globalny</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                {% if krok.pomijalne %}
                                    <span class="badge bg-secondary-lt">Pominięty</span>
                                {% else %}
                                    <span class="badge bg-green-lt">Aktywny</span>
                                {% endif %}
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a href="{{ path('planer_admin_workflow_edit', {id: krok.id}) }}" class="btn btn-sm btn-outline-primary" title="Edytuj">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24"
                                             stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                            <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                                            <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
                                            <path d="M16 5l3 3"/>
                                        </svg>
                                    </a>
                                    <form method="post" action="{{ path('planer_admin_workflow_delete', {id: krok.id}) }}"
                                          onsubmit="return confirm('Usunąć ten krok workflow?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Usuń">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24"
                                                 stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                                <path d="M4 7l16 0"/>
                                                <path d="M10 11l0 6"/>
                                                <path d="M14 11l0 6"/>
                                                <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                                                <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                                            </svg>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% else %}
    <div class="empty">
        <p class="empty-title">Brak kroków workflow</p>
        <p class="empty-subtitle text-secondary">Dodaj kroki akceptacji, aby podania mogły być przetwarzane.</p>
        <a href="{{ path('planer_admin_workflow_new') }}" class="btn btn-primary">Dodaj pierwszy krok</a>
    </div>
{% endif %}

<style>
    .cursor-grab { cursor: grab; }
    .cursor-grab:active { cursor: grabbing; }
    .sortable-ghost { opacity: 0.4; }
</style>
{% endblock %}
