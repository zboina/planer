<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        @page { margin: 2cm 2cm 1.8cm 2cm; }
        body {
            font-family: 'DejaVu Sans', sans-serif;
            font-size: 9.5pt;
            line-height: 1.4;
            color: #1a1a1a;
        }

        /* ── Header ── */
        .header { width: 100%; margin-bottom: 20px; border-bottom: 2px solid #2563eb; padding-bottom: 10px; }
        .header td { vertical-align: top; font-size: 9pt; }
        .header .col-left { width: 50%; }
        .header .col-right { width: 50%; text-align: right; }
        .header .firma-name { font-size: 11pt; font-weight: bold; color: #2563eb; }
        .header .user-name { font-size: 11pt; font-weight: bold; }
        .header .meta { color: #666; font-size: 8pt; }

        /* ── Title ── */
        .title { text-align: center; margin: 16px 0 20px 0; }
        .title h1 { font-size: 16pt; font-weight: bold; margin: 0 0 2px 0; color: #1a1a1a; letter-spacing: 1px; }
        .title .subtitle { font-size: 10pt; color: #555; }
        .title .nr { font-size: 8pt; color: #999; margin-top: 4px; }

        /* ── Data block ── */
        .data-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
        .data-table td { padding: 6px 10px; vertical-align: top; font-size: 9.5pt; }
        .data-table .label { width: 150px; color: #555; font-size: 8.5pt; text-transform: uppercase; letter-spacing: 0.3px; }
        .data-table .value { font-weight: bold; }
        .data-table tr { border-bottom: 1px solid #e5e7eb; }
        .data-table tr:last-child { border-bottom: none; }

        /* ── Period highlight ── */
        .period-box { background: #f0f7ff; border: 1px solid #bfdbfe; border-radius: 4px; padding: 10px 14px; margin-bottom: 16px; text-align: center; }
        .period-box .dates { font-size: 13pt; font-weight: bold; color: #1e40af; }
        .period-box .days { font-size: 9pt; color: #555; margin-top: 2px; }

        /* ── Content section ── */
        .section { margin-bottom: 14px; }
        .section-title { font-size: 8.5pt; text-transform: uppercase; letter-spacing: 0.5px; color: #2563eb; font-weight: bold; margin-bottom: 6px; border-bottom: 1px solid #e5e7eb; padding-bottom: 3px; }
        .section-body { font-size: 9.5pt; }

        /* ── Signature ── */
        .sig-area { margin-top: 20px; text-align: right; }
        .sig-line { border-bottom: 1px dotted #999; width: 200px; display: inline-block; height: 30px; }
        .sig-caption { font-size: 7pt; color: #999; text-align: right; }
        .sig-value { font-style: italic; font-size: 11pt; text-align: right; }

        /* ── Workflow ── */
        .workflow-section { margin-top: 24px; border-top: 2px solid #2563eb; padding-top: 12px; }
        .workflow-chain { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
        .workflow-chain td { text-align: center; padding: 4px 2px; font-size: 8pt; vertical-align: middle; }
        .wf-step { background: #f3f4f6; border: 1px solid #d1d5db; border-radius: 3px; padding: 4px 8px; font-weight: bold; }
        .wf-step.active { background: #dbeafe; border-color: #93c5fd; color: #1e40af; }
        .wf-step.done { background: #dcfce7; border-color: #86efac; color: #166534; }
        .wf-step.rejected { background: #fee2e2; border-color: #fca5a5; color: #991b1b; }
        .wf-step.cancelled { background: #f3f4f6; border-color: #d1d5db; color: #6b7280; }
        .wf-arrow { color: #9ca3af; font-size: 10pt; }

        /* ── Log table ── */
        .log-table { width: 100%; border-collapse: collapse; font-size: 8.5pt; }
        .log-table th { background: #f9fafb; border: 1px solid #e5e7eb; padding: 4px 8px; text-align: left; font-size: 8pt; text-transform: uppercase; color: #555; }
        .log-table td { border: 1px solid #e5e7eb; padding: 4px 8px; }
        .log-table .log-accept { color: #166534; }
        .log-table .log-reject { color: #991b1b; }
        .log-table .log-cancel { color: #6b7280; }

        /* ── Approval boxes ── */
        .approval-grid { width: 100%; border-collapse: collapse; margin-top: 14px; }
        .approval-grid td { width: 50%; border: 1px solid #d1d5db; padding: 8px 10px; vertical-align: top; }
        .approval-label { font-size: 8pt; color: #555; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 10px; }
        .approval-sig { border-bottom: 1px dotted #999; height: 35px; margin-top: 4px; }
        .approval-caption { font-size: 7pt; color: #999; margin-top: 2px; }
        .approval-filled { font-size: 9pt; }
        .approval-filled .name { font-weight: bold; }
        .approval-filled .date { color: #666; font-size: 8pt; }
        .approval-filled .status { font-weight: bold; margin-top: 2px; }
        .status-accept { color: #166534; }
        .status-reject { color: #991b1b; }

        .bottom-note { font-size: 7pt; color: #999; margin-top: 10px; text-align: center; }
    </style>
</head>
<body>

{# ── HEADER ── #}
<table class="header" cellpadding="0" cellspacing="0">
    <tr>
        <td class="col-left">
            <div class="user-name">{{ planer_name(user) }}</div>
            <div class="meta">
                {% if departament is defined and departament %}{{ departament.nazwa }}<br>{% endif %}
                {% if planer_adres(user) %}{{ planer_adres(user)|nl2br }}{% endif %}
            </div>
        </td>
        <td class="col-right">
            <div class="firma-name">{{ firmaNazwa }}</div>
            <div class="meta">{{ firmaAdres|nl2br }}</div>
        </td>
    </tr>
</table>

{# ── TITLE ── #}
<div class="title">
    <h1>PODANIE O URLOP</h1>
    <div class="subtitle">
        {% if rodzajUrlopu %}{{ rodzajUrlopu.nazwa }}{% else %}wypoczynkowy{% endif %}
        {% if typPodania %} &mdash; {{ typPodania.nazwa }}{% endif %}
    </div>
    {% if podanie is defined and podanie %}<div class="nr">Nr {{ podanie.id }} &middot; złożono {{ dataZlozenia|date('d.m.Y') }}</div>{% endif %}
</div>

{# ── PERIOD ── #}
<div class="period-box">
    <div class="dates">{{ dataOd|date('d.m.Y') }} &mdash; {{ dataDo|date('d.m.Y') }}</div>
    {% set diff = dataDo|date('U') - dataOd|date('U') %}
    {% set days = ((diff / 86400)|round(0, 'floor')) + 1 %}
    <div class="days">{{ days }} {{ days == 1 ? 'dzień' : (days < 5 ? 'dni' : 'dni') }}</div>
</div>

{# ── DETAILS ── #}
<table class="data-table">
    {% if telefon %}
    <tr>
        <td class="label">Telefon kontaktowy</td>
        <td class="value">{{ telefon }}</td>
    </tr>
    {% endif %}
    {% if zastepca %}
    <tr>
        <td class="label">Zastępca</td>
        <td class="value">{{ zastepca }}</td>
    </tr>
    {% endif %}
    {% if uzasadnienie is defined and uzasadnienie %}
    <tr>
        <td class="label">Uzasadnienie</td>
        <td class="value">{{ uzasadnienie }}</td>
    </tr>
    {% endif %}
</table>

{# ── SIGNATURE ── #}
<div class="sig-area">
    {% if podpis is defined and podpis %}
        <div class="sig-value">{{ podpis }}</div>
    {% else %}
        <div class="sig-line"></div>
    {% endif %}
    <div class="sig-caption">(podpis pracownika)</div>
</div>

{# ── WORKFLOW SECTION ── #}
{% if workflowSteps is defined and workflowSteps is not empty %}
<div class="workflow-section">
    <div class="section-title">Workflow akceptacji</div>

    {# Visual chain #}
    {% set currentStatus = podanie is defined ? podanie.status : 'zlozony' %}
    {% set isRejected = currentStatus == 'odrzucony' %}
    {% set isCancelled = currentStatus == 'anulowany' %}
    {% set isApproved = currentStatus == 'zatwierdzony' %}

    {# Determine which steps are done #}
    {% set doneStepKeys = [] %}
    {% if logs is defined %}
        {% for log in logs %}
            {% if log.transition starts with 'akceptuj_' %}
                {% set stepKey = log.transition[9:] %}
                {% set doneStepKeys = doneStepKeys|merge([stepKey]) %}
            {% endif %}
        {% endfor %}
    {% endif %}

    <table class="workflow-chain">
        <tr>
            <td><span class="wf-step done">Złożony</span></td>
            {% for step in workflowSteps %}
                <td class="wf-arrow">&rarr;</td>
                {% if step.key in doneStepKeys %}
                    <td><span class="wf-step done">{{ step.label }}</span></td>
                {% elseif isRejected %}
                    <td><span class="wf-step rejected">{{ step.label }}</span></td>
                {% elseif isCancelled %}
                    <td><span class="wf-step cancelled">{{ step.label }}</span></td>
                {% elseif podanie_next_step(currentStatus) == step.label %}
                    <td><span class="wf-step active">{{ step.label }}</span></td>
                {% else %}
                    <td><span class="wf-step">{{ step.label }}</span></td>
                {% endif %}
            {% endfor %}
            <td class="wf-arrow">&rarr;</td>
            {% if isApproved %}
                <td><span class="wf-step done">Zatwierdzony</span></td>
            {% elseif isRejected %}
                <td><span class="wf-step rejected">Odrzucony</span></td>
            {% elseif isCancelled %}
                <td><span class="wf-step cancelled">Anulowany</span></td>
            {% else %}
                <td><span class="wf-step">Zatwierdzony</span></td>
            {% endif %}
        </tr>
    </table>

    {# Approval boxes for each step #}
    {% if workflowSteps|length > 0 %}
    <table class="approval-grid">
        {% for step in workflowSteps %}
            {% if loop.index is odd %}<tr>{% endif %}
            <td>
                <div class="approval-label">{{ step.label }}</div>
                {% set stepLog = null %}
                {% if logs is defined %}
                    {% for log in logs %}
                        {% if log.transition == 'akceptuj_' ~ step.key or log.transition == 'odrzuc_' ~ step.key %}
                            {% set stepLog = log %}
                        {% endif %}
                    {% endfor %}
                {% endif %}

                {% if stepLog %}
                    <div class="approval-filled">
                        {% if stepLog.transition starts with 'akceptuj_' %}
                            <div class="status status-accept">&#10003; ZAAKCEPTOWANO</div>
                        {% else %}
                            <div class="status status-reject">&#10007; ODRZUCONO</div>
                        {% endif %}
                        {% if stepLog.user %}<div class="name">{{ planer_name(stepLog.user) }}</div>{% endif %}
                        <div class="date">{{ stepLog.createdAt|date('d.m.Y H:i') }}</div>
                        {% if stepLog.komentarz %}<div style="font-size:8pt; color:#991b1b; margin-top:2px;">{{ stepLog.komentarz }}</div>{% endif %}
                    </div>
                {% else %}
                    <div class="approval-sig"></div>
                    <div class="approval-caption">(data i podpis)</div>
                {% endif %}
            </td>
            {% if loop.index is even or loop.last %}</tr>{% endif %}
        {% endfor %}
    </table>
    {% endif %}

    {# Detailed log #}
    {% if logs is defined and logs is not empty %}
    <div style="margin-top: 12px;">
        <div class="section-title">Historia zmian statusu</div>
        <table class="log-table">
            <thead>
                <tr>
                    <th style="width:100px;">Data</th>
                    <th>Operacja</th>
                    <th>Osoba</th>
                    <th>Uwagi</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>{{ dataZlozenia|date('d.m.Y H:i') }}</td>
                    <td>Złożenie podania</td>
                    <td>{{ planer_name(user) }}</td>
                    <td></td>
                </tr>
                {% for log in logs %}
                    <tr>
                        <td>{{ log.createdAt|date('d.m.Y H:i') }}</td>
                        <td class="{{ log.transition starts with 'akceptuj_' ? 'log-accept' : (log.transition starts with 'odrzuc_' ? 'log-reject' : 'log-cancel') }}">
                            {% if log.transition starts with 'akceptuj_' %}
                                Akceptacja: {{ podanie_status_label(log.toStatus) }}
                            {% elseif log.transition starts with 'odrzuc_' %}
                                Odrzucenie
                            {% elseif log.transition == 'anuluj' %}
                                Anulowanie
                            {% else %}
                                {{ log.transition }}
                            {% endif %}
                        </td>
                        <td>{% if log.user %}{{ planer_name(log.user) }}{% endif %}</td>
                        <td>{{ log.komentarz ?? '' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% endif %}
</div>
{% endif %}

<div class="bottom-note">Wygenerowano {{ "now"|date('d.m.Y H:i') }}</div>

</body>
</html>
