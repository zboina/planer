{% set canvasJson = szablon is defined and szablon ? szablon.canvasJson|default('') : '' %}
{% set szablonId = szablon is defined and szablon ? szablon.id : 0 %}
{% set previewUrl = szablon is defined and szablon ? path('planer_admin_szablon_preview_pdf', {id: szablon.id}) : '' %}
{% set previewNewUrl = path('planer_admin_szablon_preview_pdf_new') %}
{% set isLegacy = szablon is defined and szablon and szablon.trescHtml and not szablon.canvasJson %}
{% set placeholderList = [] %}
{% for placeholder, opis in placeholders %}
    {% set placeholderList = placeholderList|merge([placeholder]) %}
{% endfor %}

<div data-controller="szablon-editor"
     data-szablon-editor-canvas-json-value="{{ canvasJson|e('html_attr') }}"
     data-szablon-editor-placeholders-value="{{ placeholderList|json_encode|e('html_attr') }}"
     data-szablon-editor-preview-url-value="{{ previewUrl }}"
     data-szablon-editor-preview-new-url-value="{{ previewNewUrl }}"
     data-szablon-editor-szablon-id-value="{{ szablonId }}"
     data-szablon-editor-legacy-value="{{ isLegacy ? '1' : '0' }}">

    {# ── Nazwa szablonu ── #}
    <div class="mb-3">
        <label class="form-label required" for="nazwa">Nazwa szablonu</label>
        <input type="text" class="form-control" id="nazwa" name="nazwa"
               value="{{ szablon is defined and szablon ? szablon.nazwa : '' }}" required maxlength="100"
               placeholder="np. Podanie o urlop">
    </div>

    {# ══ Legacy: tryb HTML ══ #}
    <div data-szablon-editor-target="legacyMode" class="{{ not isLegacy ? 'd-none' : '' }}">
        <div class="alert alert-info d-flex align-items-center justify-content-between mb-2">
            <div><i class="ti ti-info-circle me-1"></i> Ten szablon używa ręcznego kodu HTML.</div>
            <button type="button" class="btn btn-sm btn-outline-primary" data-action="szablon-editor#switchToCanvas">
                <i class="ti ti-artboard me-1"></i>Przełącz na edytor wizualny
            </button>
        </div>
        <div class="mb-3">
            <textarea class="form-control" id="legacy_tresc_html" data-szablon-editor-target="legacyTextarea" rows="20"
                      style="font-family:'SFMono-Regular',Menlo,Monaco,Consolas,monospace;font-size:0.82rem;tab-size:4;">{{ szablon is defined and szablon ? szablon.trescHtml : '' }}</textarea>
        </div>
        <div class="mb-3">
            <label class="form-label small">Placeholdery</label>
            <div class="d-flex flex-wrap gap-1">
                {% for placeholder, opis in placeholders %}
                    <button type="button" class="btn btn-sm btn-outline-primary py-0 px-1" style="font-size:0.7rem;"
                            data-action="szablon-editor#insertPlaceholderLegacy"
                            data-placeholder="{{ placeholder }}" title="{{ opis }}">{{ placeholder }}</button>
                {% endfor %}
            </div>
        </div>
        <button type="button" class="btn btn-sm btn-outline-info mb-3" data-action="szablon-editor#previewPdf">
            <i class="ti ti-file-type-pdf me-1"></i>Podgląd PDF
        </button>
    </div>

    {# ══ Canvas: tryb wizualny ══ #}
    <div data-szablon-editor-target="canvasMode" class="{{ isLegacy ? 'd-none' : '' }}">

        {% if isLegacy %}
            <div class="alert alert-warning d-flex align-items-center justify-content-between mb-2 py-1">
                <div><i class="ti ti-artboard me-1"></i> Edytor wizualny</div>
                <button type="button" class="btn btn-sm btn-outline-secondary py-0" data-action="szablon-editor#switchToLegacy">
                    <i class="ti ti-code me-1"></i>Wróć do HTML
                </button>
            </div>
        {% endif %}

        <div data-szablon-editor-target="fullscreenContainer">
            <div class="d-flex gap-0" style="min-height: 600px;">

                {# ╔══════════════════════════════════╗ #}
                {# ║  LEWY SIDEBAR                    ║ #}
                {# ╚══════════════════════════════════╝ #}
                <div class="border-end bg-white" style="width:210px; flex-shrink:0; overflow-y:auto; font-size:0.8rem;" data-szablon-editor-target="sidebar">

                    {# — Dodaj elementy — #}
                    <div class="px-2 py-2 border-bottom">
                        <div class="fw-bold text-muted mb-1" style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.5px;">Dodaj element</div>
                        <div class="d-flex gap-1 flex-wrap">
                            <button type="button" class="btn btn-sm btn-outline-primary py-0 px-2" data-action="szablon-editor#addText" title="Dodaj tekst">
                                <i class="ti ti-text-size" style="font-size:0.85rem;"></i> Tekst
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-primary py-0 px-2" data-action="szablon-editor#addLine" title="Linia">
                                <i class="ti ti-line" style="font-size:0.85rem;"></i> Linia
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-primary py-0 px-2" data-action="szablon-editor#addRect" title="Prostokąt">
                                <i class="ti ti-square" style="font-size:0.85rem;"></i> Prostokąt
                            </button>
                        </div>
                        <div class="d-flex gap-1 flex-wrap mt-1">
                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2" data-action="szablon-editor#addImage" title="Dodaj obrazek">
                                <i class="ti ti-photo" style="font-size:0.85rem;"></i> Obrazek
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2" data-action="szablon-editor#addSignatureArea" title="Obszar podpisu">
                                <i class="ti ti-signature" style="font-size:0.85rem;"></i> Podpis
                            </button>
                        </div>
                        <input type="file" class="d-none" accept="image/*" data-szablon-editor-target="imageFile"
                               data-action="change->szablon-editor#handleImageFile">
                    </div>

                    {# — Tryb rysowania — #}
                    <div class="px-2 py-2 border-bottom">
                        <div class="fw-bold text-muted mb-1" style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.5px;">Rysowanie</div>
                        <div class="d-flex gap-1 align-items-center mb-1">
                            <button type="button" class="btn btn-sm btn-outline-warning py-0 px-2" data-szablon-editor-target="drawBtn"
                                    data-action="szablon-editor#toggleDrawing" title="Tryb rysowania odręcznego">
                                <i class="ti ti-pencil" style="font-size:0.85rem;"></i> Rysuj
                            </button>
                            <input type="color" class="form-control form-control-sm form-control-color p-0 border-0"
                                   data-szablon-editor-target="drawColor"
                                   data-action="input->szablon-editor#updateDrawColor"
                                   value="#000000" title="Kolor rysowania" style="width:24px;height:24px;">
                        </div>
                        <div class="d-flex gap-1 align-items-center">
                            <label class="form-label mb-0" style="font-size:0.6rem;">Grubość:</label>
                            <input type="range" class="form-range flex-grow-1" min="1" max="10" value="2" style="height:18px;"
                                   data-szablon-editor-target="drawWidth"
                                   data-action="input->szablon-editor#updateDrawWidth">
                        </div>
                    </div>

                    {# — Siatka (grid) — #}
                    <div class="px-2 py-2 border-bottom">
                        <div class="fw-bold text-muted mb-1" style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.5px;">Siatka</div>
                        <div class="d-flex gap-1 align-items-center mb-1">
                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2"
                                    data-szablon-editor-target="gridToggle"
                                    data-action="szablon-editor#toggleGrid" title="Włącz/wyłącz siatkę">
                                <i class="ti ti-grid-dots" style="font-size:0.85rem;"></i> Siatka
                            </button>
                        </div>
                        <div class="d-flex gap-1 align-items-center">
                            <label class="form-label mb-0" style="font-size:0.6rem; white-space:nowrap;">Rozmiar:</label>
                            <input type="number" class="form-control form-control-sm text-center" style="font-size:0.75rem; width:60px;"
                                   min="5" max="100" value="10"
                                   data-szablon-editor-target="gridSize"
                                   data-action="change->szablon-editor#updateGridSize keydown->szablon-editor#preventSubmit">
                            <span class="text-muted" style="font-size:0.6rem;">px</span>
                        </div>
                    </div>

                    {# — Placeholdery — #}
                    <div class="px-2 py-2 border-bottom">
                        <div class="fw-bold text-muted mb-1" style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.5px;">Placeholder</div>
                        <select class="form-select form-select-sm mb-1" data-szablon-editor-target="placeholderSelect" style="font-size:0.75rem;">
                            <option value="">-- wybierz --</option>
                            {% for placeholder, opis in placeholders %}
                                <option value="{{ placeholder }}" title="{{ opis }}">{{ placeholder }}</option>
                            {% endfor %}
                        </select>
                        <button type="button" class="btn btn-sm btn-outline-secondary py-0 w-100" data-action="szablon-editor#addPlaceholder">
                            <i class="ti ti-plus" style="font-size:0.8rem;"></i> Wstaw placeholder
                        </button>
                    </div>

                    {# — Formatowanie tekstu — #}
                    <div class="px-2 py-2 border-bottom">
                        <div class="fw-bold text-muted mb-1" style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.5px;">Formatowanie</div>
                        <div class="d-flex gap-1 align-items-center mb-1">
                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1" data-action="szablon-editor#toggleBold" title="Pogrubienie (Ctrl+B)">
                                <i class="ti ti-bold"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1" data-action="szablon-editor#toggleItalic" title="Kursywa (Ctrl+I)">
                                <i class="ti ti-italic"></i>
                            </button>
                            <div class="vr mx-1"></div>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1" data-action="szablon-editor#alignLeft" title="Do lewej">
                                <i class="ti ti-align-left"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1" data-action="szablon-editor#alignCenter" title="Wyśrodkuj">
                                <i class="ti ti-align-center"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-1" data-action="szablon-editor#alignRight" title="Do prawej">
                                <i class="ti ti-align-right"></i>
                            </button>
                        </div>
                        <div class="row g-1">
                            <div class="col-6">
                                <label class="form-label mb-0" style="font-size:0.65rem;">Rozmiar</label>
                                <input type="number" class="form-control form-control-sm text-center" style="font-size:0.75rem;"
                                       min="4" max="200" value="12"
                                       data-szablon-editor-target="fontSize"
                                       data-action="change->szablon-editor#updateFontSize keydown->szablon-editor#preventSubmit">
                            </div>
                            <div class="col-3">
                                <label class="form-label mb-0" style="font-size:0.65rem;">Kolor</label>
                                <input type="color" class="form-control form-control-sm form-control-color w-100 p-0"
                                       data-szablon-editor-target="fontColor"
                                       data-action="input->szablon-editor#updateFontColor"
                                       value="#000000" title="Kolor tekstu" style="height:26px;">
                            </div>
                            <div class="col-3">
                                <label class="form-label mb-0" style="font-size:0.65rem;">Tło</label>
                                <input type="color" class="form-control form-control-sm form-control-color w-100 p-0"
                                       data-szablon-editor-target="fillColor"
                                       data-action="input->szablon-editor#updateFillColor"
                                       value="#ffffff" title="Kolor tła" style="height:26px;">
                            </div>
                        </div>
                    </div>

                    {# — Właściwości zaznaczonego — #}
                    <div class="px-2 py-2 border-bottom d-none" data-szablon-editor-target="propPanel">
                        <div class="fw-bold text-muted mb-1" style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.5px;">Właściwości</div>
                        <div class="row g-1 mb-1">
                            <div class="col-6">
                                <label class="form-label mb-0" style="font-size:0.6rem;">X</label>
                                <input type="number" class="form-control form-control-sm" style="font-size:0.75rem;"
                                       data-szablon-editor-target="propX"
                                       data-action="change->szablon-editor#updatePropX keydown->szablon-editor#preventSubmit">
                            </div>
                            <div class="col-6">
                                <label class="form-label mb-0" style="font-size:0.6rem;">Y</label>
                                <input type="number" class="form-control form-control-sm" style="font-size:0.75rem;"
                                       data-szablon-editor-target="propY"
                                       data-action="change->szablon-editor#updatePropY keydown->szablon-editor#preventSubmit">
                            </div>
                        </div>
                        <div class="row g-1 mb-1">
                            <div class="col-6">
                                <label class="form-label mb-0" style="font-size:0.6rem;">Szerokość</label>
                                <input type="number" class="form-control form-control-sm" style="font-size:0.75rem;"
                                       data-szablon-editor-target="propW"
                                       data-action="change->szablon-editor#updatePropW keydown->szablon-editor#preventSubmit">
                            </div>
                            <div class="col-6">
                                <label class="form-label mb-0" style="font-size:0.6rem;">Wysokość</label>
                                <input type="number" class="form-control form-control-sm" style="font-size:0.75rem;"
                                       data-szablon-editor-target="propH"
                                       data-action="change->szablon-editor#updatePropH keydown->szablon-editor#preventSubmit">
                            </div>
                        </div>
                        <div class="row g-1 mb-1">
                            <div class="col-6">
                                <label class="form-label mb-0" style="font-size:0.6rem;">Obrót</label>
                                <div class="input-group input-group-sm">
                                    <input type="number" class="form-control form-control-sm" style="font-size:0.75rem;"
                                           data-szablon-editor-target="propAngle"
                                           data-action="change->szablon-editor#updatePropAngle keydown->szablon-editor#preventSubmit">
                                    <span class="input-group-text px-1" style="font-size:0.6rem;">°</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <label class="form-label mb-0" style="font-size:0.6rem;">Przezroczystość</label>
                                <input type="range" class="form-range" min="0" max="100" value="100" style="height:26px;"
                                       data-szablon-editor-target="propOpacity"
                                       data-action="input->szablon-editor#updatePropOpacity">
                            </div>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-danger py-0 w-100" data-action="szablon-editor#deleteSelected">
                            <i class="ti ti-trash" style="font-size:0.8rem;"></i> Usuń zaznaczone
                        </button>
                    </div>

                    {# — Wzór z PDF — #}
                    <div class="px-2 py-2 border-bottom">
                        <div class="fw-bold text-muted mb-1" style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.5px;">Wzór z PDF</div>
                        <input type="file" class="form-control form-control-sm mb-1" accept=".pdf,application/pdf" style="font-size:0.7rem;"
                               data-szablon-editor-target="pdfFile"
                               data-action="change->szablon-editor#loadPdfBackground">
                        <div class="d-none" data-szablon-editor-target="bgControls">
                            <div class="d-flex align-items-center gap-1">
                                <input type="range" class="form-range flex-grow-1" min="5" max="100" value="30" style="height:20px;"
                                       data-szablon-editor-target="bgOpacity"
                                       data-action="input->szablon-editor#updateBgOpacity">
                                <span class="text-muted" style="font-size:0.65rem; min-width:28px;" data-szablon-editor-target="bgOpacityValue">30%</span>
                                <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" data-action="szablon-editor#removePdfBackground" title="Usuń tło">
                                    <i class="ti ti-x" style="font-size:0.75rem;"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    {# — Pola formularza — #}
                    <div class="px-2 py-2 border-bottom">
                        <div class="fw-bold text-muted mb-1" style="font-size:0.65rem; text-transform:uppercase; letter-spacing:0.5px;">Pola formularza</div>
                        {% set polaOpcje = {
                            typ_podania: 'Typ podania',
                            rodzaj_urlopu: 'Rodzaj urlopu',
                            zastepca: 'Zastępca',
                            telefon: 'Telefon',
                            uzasadnienie: 'Uzasadnienie',
                            podpis: 'Podpis',
                            adres: 'Adres'
                        } %}
                        {% set currentPola = szablon is defined and szablon ? szablon.polaFormularza : [] %}
                        {% for key, label in polaOpcje %}
                            <label class="form-check mb-0">
                                <input class="form-check-input" type="checkbox" name="pola_formularza[]" value="{{ key }}"
                                       {{ key in currentPola ? 'checked' : '' }} style="width:14px;height:14px;">
                                <span class="form-check-label" style="font-size:0.75rem;">{{ label }}</span>
                            </label>
                        {% endfor %}
                    </div>

                    {# — Aktywny — #}
                    <div class="px-2 py-2 border-bottom">
                        <label class="form-check mb-0">
                            <input class="form-check-input" type="checkbox" name="aktywny" value="1"
                                   {{ (szablon is not defined or szablon is null or szablon.aktywny) ? 'checked' : '' }} style="width:14px;height:14px;">
                            <span class="form-check-label fw-bold" style="font-size:0.75rem;">Aktywny</span>
                        </label>
                    </div>

                    {# — Akcje — #}
                    <div class="px-2 py-2">
                        <div class="d-grid gap-1">
                            <button type="button" class="btn btn-sm btn-outline-info py-0" data-action="szablon-editor#previewPdf">
                                <i class="ti ti-file-type-pdf" style="font-size:0.8rem;"></i> Podgląd PDF
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-dark py-0" data-action="szablon-editor#toggleFullscreen">
                                <i class="ti ti-maximize" style="font-size:0.8rem;"></i> Pełny ekran
                            </button>
                        </div>
                    </div>
                </div>

                {# ╔══════════════════════════════════╗ #}
                {# ║  OBSZAR KANWY                    ║ #}
                {# ╚══════════════════════════════════╝ #}
                <div class="flex-grow-1" style="min-width:0; background:#e9ecef; overflow:auto; display:flex; justify-content:center; align-items:flex-start; padding:16px;">
                    <div style="box-shadow:0 2px 12px rgba(0,0,0,0.15);">
                        <canvas data-szablon-editor-target="canvas"></canvas>
                    </div>
                </div>

            </div>
        </div>{# /fullscreenContainer #}
    </div>

    {# ── Hidden inputs ── #}
    <input type="hidden" name="tresc_html" data-szablon-editor-target="trescHtml"
           value="{{ szablon is defined and szablon ? szablon.trescHtml|e('html_attr') : '' }}">
    <input type="hidden" name="canvas_json" data-szablon-editor-target="canvasJson"
           value="{{ canvasJson|e('html_attr') }}">

</div>
