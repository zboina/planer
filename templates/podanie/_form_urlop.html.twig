{# Pola specyficzne dla podania o urlop #}
<div class="row mb-3">
    <div class="col-md-3">
        <label class="form-label required" for="typ_podania_id">Typ podania</label>
        <select class="form-select form-select-sm" id="typ_podania_id" name="typ_podania_id" required>
            {% for typ in typyPodania %}
                <option value="{{ typ.id }}"{{ loop.first ? ' selected' : '' }}>{{ typ.nazwa }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label required" for="rodzaj_urlopu_id">Rodzaj urlopu</label>
        <select class="form-select form-select-sm" id="rodzaj_urlopu_id" name="rodzaj_urlopu_id" required>
            {% for rodzaj in rodzajeUrlopu %}
                <option value="{{ rodzaj.id }}"{{ loop.first ? ' selected' : '' }}>{{ rodzaj.nazwa }}</option>
            {% endfor %}
        </select>
    </div>
    {% if wspolpracownicy|length > 0 %}
    <div class="col-md-3">
        <label class="form-label required" for="zastepca">Zastępca</label>
        <select class="form-select form-select-sm" id="zastepca" name="zastepca" required>
            <option value="">— wybierz —</option>
            {% for w in wspolpracownicy %}
                <option value="{{ planer_name(w) }}">{{ planer_name(w) }}</option>
            {% endfor %}
        </select>
    </div>
    {% endif %}
    <div class="col-md-3">
        <label class="form-label required" for="telefon">Telefon kontaktowy</label>
        <input type="text" class="form-control form-control-sm" id="telefon" name="telefon" required placeholder="np. 600 123 456">
    </div>
</div>
<div class="row mb-3" data-controller="signature-pad">
    <div class="col-md-6">
        <div class="d-flex align-items-center justify-content-between mb-1">
            <label class="form-label mb-0" for="podpis_text_urlop">Podpis na wydruku</label>
            <button type="button" class="btn btn-outline-secondary btn-sm"
                    data-signature-pad-target="toggleBtn"
                    data-action="signature-pad#toggle">
                <i class="ti ti-signature me-1"></i>Podpisz odręcznie
            </button>
        </div>
        <input type="hidden" name="podpis" value="" data-signature-pad-target="hiddenInput">
        <div data-signature-pad-target="textContainer">
            <input type="text" class="form-control form-control-sm" id="podpis_text_urlop"
                   placeholder="Opcjonalnie — wpisz imię i nazwisko"
                   data-signature-pad-target="textInput"
                   data-action="input->signature-pad#syncText">
        </div>
        <div data-signature-pad-target="padContainer" style="display:none;">
            <div class="border rounded p-1 bg-white" style="cursor:crosshair;">
                <canvas data-signature-pad-target="canvas"
                        style="width:100%;height:120px;display:block;touch-action:none;"
                        data-action="mousedown->signature-pad#startDraw
                                     mousemove->signature-pad#draw
                                     mouseup->signature-pad#endDraw
                                     mouseleave->signature-pad#endDraw
                                     touchstart->signature-pad#startDraw
                                     touchmove->signature-pad#draw
                                     touchend->signature-pad#endDraw"></canvas>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-1">
                <small class="text-muted">Narysuj podpis myszką lub palcem</small>
                <button type="button" class="btn btn-outline-danger btn-sm"
                        data-signature-pad-target="clearBtn"
                        data-action="signature-pad#clear">
                    <i class="ti ti-eraser me-1"></i>Wyczyść
                </button>
            </div>
        </div>
    </div>
</div>
{% if editAdres is defined and editAdres %}
    <div class="mb-3">
        <label class="form-label" for="adres">Adres zamieszkania</label>
        <input type="text" class="form-control form-control-sm" id="adres" name="adres"
               placeholder="np. ul. Przykładowa 1, 00-001 Warszawa" value="{{ planer_adres(user) }}">
        <small class="form-hint">Adres zostanie zapisany w Twoim profilu i użyty w podaniu.</small>
    </div>
{% endif %}
